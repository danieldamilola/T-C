{
  "manifest_version": 3,
  "name": "T&C Lens",
  "version": "1.0.0",
  "description": "AI-powered Terms & Conditions analyzer. Understand what you're agreeing to.",
  "permissions": ["activeTab", "contextMenus", "scripting", "storage", "tabs"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "T&C Lens — Analyze this page"
  }
}
